{
  "name": "neiist",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "setup": "chmod +x ./scripts/setup.sh && ./scripts/setup.sh",
    "release": "yarn changeset && yarn changeset version && yarn changeset publish",
    "dev": "docker compose -f ./docker/docker-compose.yml up -d && next dev --turbopack; docker compose -f ./docker/docker-compose.yml stop > /dev/null 2>&1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint -c ./config/eslint/eslint.config.mjs .",
    "lint:fix": "eslint -c ./config/eslint/eslint.config.mjs --fix .",
    "lint:staged": "lint-staged -c ./config/eslint/lintstagedrc.mjs",
    "format": "prettier --config ./config/prettier/.prettierrc.json --ignore-path ./config/prettier/.prettierignore --write .",
    "format:check": "prettier --config ./config/prettier/.prettierrc.json --ignore-path ./config/prettier/.prettierignore --check .",
    "type:check": "tsc --noEmit",
    "db:reset": "docker compose -f ./docker/docker-compose.yml down && docker volume rm neiist_db && docker compose -f ./docker/docker-compose.yml up -d",
    "clean": "rm -rf .next out dist build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@notionhq/client": "^5.20.0",
    "@sumup/sdk": "^0.1.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react-big-calendar": "^1.16.3",
    "baseline-browser-mapping": "^2.10.29",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.3.0",
    "googleapis": "^171.4.0",
    "hamburger-react": "^2.5.2",
    "ical-generator": "^10.2.0",
    "jsonwebtoken": "^9.0.3",
    "linkify-react": "^4.3.2",
    "linkifyjs": "^4.0.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.7",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "react": "19.2.6",
    "react-big-calendar": "1.19.4",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.6",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7",
    "swiper": "^12.1.4",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "16.2.6",
    "@types/node": "^25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-validate-filename": "^1.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "node-cron": "^4.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
